{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "goal":{
            "_comment": [
                "Using 'goal' as the name of an option let you override some of the generated goal parameters"
            ],
            "display_name": "The End Objective",
            "description": "How to End your Randomized playthrough.",
            "aliases": {"ending1 is2": 0, "ending2 is2": 1, "ending3 is2": 2, "ending4 is2": 3,
                        "ending1 is3": 4, "ending2 is3": 5, "ending3 is3": 6, "ending4 is3": 7,
                        "ending1 is4": 8, "ending2 is4": 9, "ending3 is4": 10, "ending4 is4": 11,
                        "ending1 is5": 12, "ending2 is5": 13, "ending3 is5": 14, "ending4 is5": 15, "ending5 is5": 16,
                        "ending1 is6": 17, "ending2 is6": 18, "ending3 is6": 19
                    },
            "hidden": false
        },
        "death_link": {
            "default": false
        },
        "filler_traps": {
            "_comment": "Using values here let you set a 'recommended' filler_trap percentage or even a default percentage",
            "values": {
                "recommended": 0
            },
            "hidden": true
        }
    },
    "user": {
        "include 6 stars":{
            "description": [
                "include or exclude all six stars from the randomizer.",
                "if excluded (false), you can't play any 6 stars. in all the runs.",
                "in the template yaml, you can also choose which individual 6 star should be removed.",
                "This is done, becuase there is no way to do ti via the json file (yet)."
            ],
            "type": "Toggle",
            "default": true,
            "group": "operator options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui"
            ]
        },
        "include 5 stars":{
            "description": [
                "how the 5 stars will be randomised",
                "'as individual items': all 5 stars are individual items. When you get this, you instantly get access to e2",
                "'progressive items': all 5 stars are progressive items. first item, you unlock all 5 stars. Second progressive item unlocks e2",
                "'exclude': no 5 stars will be included. Alternatively could be used as you can always use 5 stars"
            ],
            "type": "Choice",
            "values": {
                "as individual items": 0,
                "progressive items": 1,
                "exclude": 2
            },
            "group": "operator options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui"
            ]
        },
        "_include 4 stars":{
            "description": [
                "how the 4 stars will be randomised",
                "'progressive items': all 4 stars are progressive items. first item, you unlock all 4 stars. Second progressive item unlocks e2",
                "'exclude': no 4 stars will be included. Alternatively could be used as you can always use 4 stars"
            ],
            "type": "Choice",
            "values": {
                "progressive items": 0,
                "exclude": 1
            },
            "group": "operator options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui"
            ]
        },
        "_include 3 stars":{
            "description": [
                "how the 3 stars will be randomised",
                "'progressive items': all 3 stars are progressive items. first item, you unlock all 3 stars. Second progressive item unlocks e2",
                "'exclude': no 3 stars will be included. Alternatively could be used as you can always use 3 stars"
            ],
            "type": "Choice",
            "values": {
                "progressive items": 0,
                "exclude": 1
            },
            "group": "operator options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui"
            ]
        },
        "include ed1": {
            "type": "Toggle",
            "default": true,
            "description": ["all the required items and stages for ending 1 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed2": {
            "type": "Toggle",
            "default": true,
            "description": ["all the required items and stages for ending 2 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed3": {
            "type": "Toggle",
            "default": true,
            "description": ["all the required items and stages for ending 3 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed4": {
            "type": "Toggle",
            "default": true,
            "description": ["all the required items and stages for ending 4 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed5": {
            "type": "Toggle",
            "default": true,
            "description": ["all the required items and stages for ending 5 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "_investment of ingots": {
            "description": [
                "how many ingots you need to invest to get a check",
                "if this number is 0, then this location will be removed"
            ],
            "type": "Range",
            "range_start": 1,
            "default": 10,
            "range_end": 50,
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "_get ingots from investment": {
            "description": [
                "how many ingots you need to get from the investment to get a check",
                "if this number is 0, then this location will be removed"
            ],
            "type": "Range",
            "range_start": 1,
            "default": 5,
            "range_end": 20,
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        }, 
        "include is2": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS2 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is3": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS3 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is4": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS4 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is5": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS5 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is6": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS6 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "starting region": {
            "type": "Choice",
            "group": "IS options",
            "description": [
                "choose which is you want to start in",
                "make sure that the chosen region is also one you enabled, otherwise the gen will fail.",
                "0 = is2",
                "1 = is3",
                "2 = is4",
                "3 = is5",
                "4 = is6"
            ],
            "values": {
                "is2": 0,
                "is3": 1,
                "is4": 2,
                "is5": 3,
                "is6": 4
            }
        },
        "_include optional floor": {
            "type": "Toggle",
            "default": true,
            "description": [
                "include optional floors for the randomizer",
                "these are primarily the wander into wonderland and bosky passage locations"
            ],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include face off nodes": {
            "type": "Toggle",
            "default": true,
            "description": [
                "include face-off for the randomizer",
                "these are only found from is5 onward. This setting won't do anything in is2 to is4."
            ],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "_include perfect operation": {
            "type": "Toggle",
            "default": false,
            "description": [
                "perfect operations are clears of (emergency) operations without leaks.",
                "When clearing a level, you will see a tekst if you have a perfect operation or not.",
                "turning this on, every stage has an extra location where you need to get this perfect operation."
            ],
            "group": "sanities"
        },
        "_include encounter operations": {
            "type": "Toggle",
            "default": false,
            "description": [
                "makes the run even more RNG.",
                " when turned on, you will need to get the correct encounter on",
                "the encounter node to get the operation.",
                "when turned off, these operations won't be included."
            ],
            "group": "sanities"
        },
        "_include higher difficulty": {
            "type": "Range",
            "range_start": 1,
            "range_end": 15,
            "default": 1,
            "description": [
                "include different difficulties in the randomizer.",
                "if set to 1, you can start on any difficulty you choose.",
                "if set to a higher value, Start from the lowest difficulty and progress",
                "if you get the required key for the difficulty"
            ],
            "group": "sanities"
        },
        "quick start": {
            "type": "Toggle",
            "default": false,
            "description": [
                "When true, starting a ap you can immediately go to floor 3.",
                "when false, You must unlock floor 2 and 3 like normal."
            ],
            "group": "IS options"
        },
        "include random operators": {
            "type": "Range",
            "default": 1,
            "range_start": 0,
            "range_end": 20,
            "description": [
                "add a item for unlocking random operators.",
                "use websites like https://akgcc.github.io/randomizer/ to choose what operator you can use.",
                "alternatively, use this as 'unlock a character you want' item"
            ],
            "group": "operator options"
        }
    }
}