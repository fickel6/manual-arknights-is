{
    "$schema": "https://raw.githubusercontent.com/ManualForArchipelago/Manual/main/schemas/Manual.options.schema.json",
    "_comment": "Add a _ before an option name to comment it out and it wont be added to the apworld",
    "core": {
        "goal":{
            "_comment": [
                "Using 'goal' as the name of an option let you override some of the generated goal parameters"
            ],
            "display_name": "The End Objective",
            "description": "How to End your Randomized playthrough.",
            "aliases": {"easiest": 0},
            "hidden": false
        },
        "death_link": {
            "default": false
        },
        "filler_traps": {
            "_comment": "Using values here let you set a 'recommended' filler_trap percentage or even a default percentage",
            "values": {
                "recommended": 20
            }
        }
    },
    "user": {
        "include 6 stars":{
            "description": [
                "include or exclude all six stars from the randomizer",
                "if excluded (false), you can't play any 6 stars. in all the runs"
            ],
            "type": "Toggle",
            "default": true,
            "group": "characters options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui",
                "spoiler"
            ]
        },
        "include 5 stars":{
            "description": [
                "include or exclude all five stars from the randomizer",
                "if excluded (false), you can't play any 5 stars. in all the runs"
            ],
            "type": "Toggle",
            "default": true,
            "group": "characters options",
            "visibility": [
                "template",
                "simple_ui",
                "complex_ui",
                "spoiler"
            ]
        },
        "include ed1": {
            "type": "Toggle",
            "default": true,
            "description": ["all the itmes and stages for ending 1 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed2": {
            "type": "Toggle",
            "default": true,
            "description": ["all the itmes and stages for ending 2 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed3": {
            "type": "Toggle",
            "default": true,
            "description": ["all the itmes and stages for ending 3 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include ed4": {
            "type": "Toggle",
            "default": true,
            "description": ["all the itmes and stages for ending 4 will also be randomized"],
            "group": "Endings",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "_investment of ingots": {
            "description": [
                "how many ingots you need to invest to get a check",
                "if this number is 0, then this location will be removed"
            ],
            "type": "Range",
            "range_start": 1,
            "default": 10,
            "range_end": 50,
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "_get ingots from investment": {
            "description": [
                "how many ingots you need to get from the investment to get a check",
                "if this number is 0, then this location will be removed"
            ],
            "type": "Range",
            "range_start": 1,
            "default": 5,
            "range_end": 20,
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        }, 
        "include is2": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS2 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is3": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS3 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is4": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS4 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is5": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS5 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "include is6": {
            "type": "Toggle",
            "default": true,
            "description": ["include IS6 for the randomizer"],
            "group": "IS options",
            "visibility": [
                "template",
                "simple_ui",
                "spoiler"
            ]
        },
        "starting region": {
            "type": "Choice",
            "group": "IS options",
            "description": [
                "choose which is you want to start in",
                "0 = is2",
                "1 = is3",
                "2 = is4",
                "3 = is5",
                "4 = is6"
            ],
            "values": {
                "is2": 0,
                "is3": 1,
                "is4": 2,
                "is5": 3,
                "is6": 4
            }
        }
    }
}